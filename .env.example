# Copy to .env and adjust. Vite loads:
#   - npm run dev  → .env, .env.local, .env.development, .env.development.local
#   - npm run build → .env, .env.local, .env.production, .env.production.local
# See https://vitejs.dev/guide/env-and-mode.html

# --- Development (point at local API or staging) ---
VITE_API_BASE_URL=http://localhost:8080
# VITE_API_BASE_URL=https://your-staging-api.example.com

# Must match backend ENCRYPTION_KEY
VITE_ENCRYPTION_KEY=change-me-match-backend-encryption-key

# Paymob public key — must match backend PAYMOB_PUBLIC_KEY / same Paymob mode (test vs live)
VITE_PAYMOB_PUBLIC_KEY=

# Optional: PayPal client id for client-side flows if you expose it (often backend-only)
# PAYPAL_CLIENT_ID=

# --- Production: set in .env.production (or CI env) ---
# VITE_API_BASE_URL=https://your-production-api.example.com
# VITE_CANONICAL_ORIGIN=https://your-frontend.example.com
# VITE_PAYMOB_PUBLIC_KEY=

# Optional: tunnel / preview URL for webhooks
# VITE_NGROK_URL=
